#!/usr/bin/env bash
# nvim wrapper, fallback to bobnvim

neovim_repo="$HOME/gitrepos/neovim"
export VIMRUNTIME="$neovim_repo/runtime"
nvim_cmd="$neovim_repo/build/bin/nvim"

if [[ "$BOBNVIM" != "true" ]] && [[ -f "$nvim_cmd" ]]; then
  exec "$nvim_cmd" "$@"
  exit "$?"
else
  exec bobnvim "$@"
  exit "$?"
fi
